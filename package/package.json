{
  "name": "@sveltia/cms",
  "version": "0.105.5",
  "description": "Sveltia CMS is a modern, lightweight, Git-based headless content management system.",
  "keywords": [
    "cms",
    "content-management-system"
  ],
  "repository": {
    "type": "git",
    "url": "github:sveltia/sveltia-cms"
  },
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/react": "^19.1.13"
  },
  "publishConfig": {
    "directory": "package",
    "access": "public",
    "provenance": true
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "es5-ext",
      "esbuild",
      "exifreader",
      "svelte-preprocess"
    ]
  },
  "files": [
    "dist",
    "schema",
    "types",
    "main.d.ts"
  ],
  "main": "./dist/sveltia-cms.mjs",
  "module": "./dist/sveltia-cms.mjs",
  "exports": {
    ".": {
      "types": "./main.d.ts",
      "default": "./dist/sveltia-cms.mjs"
    }
  },
  "typesVersions": {
    ">4.0": {
      "index": [
        "./main.d.ts"
      ]
    }
  }
}
